// FizzBuzz 1..20 using counters
var fizz = 0;
var buzz = 0;
var i = 1;
while (i <= 20) {
    fizz = fizz + 1;
    buzz = buzz + 1;
    if (fizz == 3 and buzz == 5) {
        print "FizzBuzz";
        fizz = 0;
        buzz = 0;
    } else if (fizz == 3) {
        print "Fizz";
        fizz = 0;
    } else if (buzz == 5) {
        print "Buzz";
        buzz = 0;
    } else {
        print i;
    }
    i = i + 1;
}
