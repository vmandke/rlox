// Classes Trick Discussed in the Session
// Not generated by Claude

fun Account(balance) {
    fun deposit(amt) {
        balance = balance + amt;
    }

    fun withdraw(amt) {
        balance = balance - amt;
    }

    fun getattribute(name) {
        if (name == "balance") { return balance; }
        if (name == "deposit") { return deposit; }
        if (name == "withdraw") { return withdraw; }
        print "attribute error";
        return nil;
    }

    return getattribute;
}

var a = Account(100);
print a("balance");        // a.balance
a("deposit")(25);          // a.deposit(25)
a("withdraw")(10);         // a.withdraw(10)
print a("balance");        // a.balance