// Ackermann function — m=0..3, n=0..5
// Grows extremely fast: ack(3,5)=253, ack(3,6)=509
fun ack(m, n) {
  if (m == 0) { return n + 1; }
  if (n == 0) { return ack(m - 1, 1); }
  return ack(m - 1, ack(m, n - 1));
}

var m = 0;
while (m <= 3) {
  var n = 0;
  while (n <= 5) {
    print ack(m, n);
    n = n + 1;
  }
  m = m + 1;
}
